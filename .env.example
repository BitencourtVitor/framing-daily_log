# MongoDB
# Local dev: use public URL (trolley.proxy.rlwy.net)
# Railway deploy: use internal URL (mongodb.railway.internal:27017)
MONGODB_URL=mongodb://mongo:PASSWORD@trolley.proxy.rlwy.net:10723

# JWT — generate: openssl rand -base64 32
JWT_SECRET=

# Railway Object Storage (S3-compatible)
# Endpoint + bucket name: Railway dashboard → your service → Object Storage tab
STORAGE_ENDPOINT=
STORAGE_BUCKET_NAME=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# QuickBooks Time — create app at developer.intuit.com
QBT_CLIENT_ID=
QBT_CLIENT_SECRET=
QBT_REDIRECT_URI=https://your-domain.railway.app/api/auth/qbt/callback
QBT_ACCESS_TOKEN=

# Buildertrend
BT_API_KEY=
BT_BASE_URL=https://api.buildertrend.net
